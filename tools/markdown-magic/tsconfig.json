{
	"extends": "../../common/build/build-common/tsconfig.node16.json",
	"compilerOptions": {
		"rootDir": "src",
		"noEmit": true,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"inlineSources": false,
		"incremental": false,
